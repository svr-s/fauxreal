{
  "$schema": "https://raw.githubusercontent.com/svr-s/fauxreal/main/fauxreal-schema.json",
  "variable_generation_config": {
    "description": "Dataframes example",
    "faker_variables": [
      {
        "name": "random_name",
        "provider": "name",
        "kwargs": {}
      }
    ],
    "dataframes": [
      {
        "name": "users_df",
        "count": 100,
        "columns": [
          {
            "name": "name",
            "ref": "random_name"
          }
        ]
      }
    ]
  }
}
